{
    "require": {
        "php": "^8.4",
        "symfony/config": "^8.0",
        "symfony/http-kernel": "^8.0",
        "symfony/http-foundation": "^8.0",
        "symfony/routing": "^8.0",
        "symfony/dependency-injection": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/yaml": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "symfony/web-profiler-bundle": "^8.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
